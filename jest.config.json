{
    "testEnvironment": "jsdom",
    "setupFiles": [
        "raf/polyfill"
    ],
    "setupFilesAfterEnv": [
        "@testing-library/jest-dom"
    ],
    "transform": {
        "^.+\\.jsx?$": "babel-jest"
    },
    "moduleNameMapper": {
        "\\.(css|scss)$": "<rootDir>/src/tests/styleMock.js"
    }
}
